  "privacy": {
    "title": "Privacy Policy",
    "intro": "Your data privacy is a priority. This page transparently details the information we use to make the application work.",
    "section1Title": "1. Local Operation and Storage",
    "section1Text1": "The application is designed to work primarily locally on your device via LocalStorage. We store:",
    "section1Item1": "Your display preferences: Theme (Dark/Light), filters, view options.",
    "section1Item2": "Your schedule cache: To enable offline and fast access.",
    "section1Item3": "Application state: Collapsed days, auto-scroll, etc.",
    "section1Text2": "This data remains on your device and is not sent to third parties.",
    "section2Title": "2. Authentication and Database",
    "section2Text1": "For synchronization and secure access, we use Supabase (hosted on AWS). If you create an account, we securely store:",
    "section2Item1": "Your login credentials (encrypted passwords).",
    "section2Item2": "Your synchronization settings.",
    "section2Text2": "Access to this data is strictly limited to service operation.",
    "section3Title": "3. Cookies",
    "section3Text1": "We use a minimal number of cookies, only for:",
    "section3Item1": "Maintaining your connected session (edt_session).",
    "section3Item2": "Remembering your consent choice.",
    "section3Text2": "No advertising or third-party tracking cookies are used.",
    "section4Title": "4. Your Rights",
    "section4Text1": "You keep full control. You can at any time:",
    "section4Item1": "Clear the application cache (via settings).",
    "section4Item2": "Delete your account and associated data.",
    "section4Item3": "Request access or correction of your information by contacting us.",
    "footerText": "For any questions:",
    "backToDashboard": "Back to dashboard",
    "backToEDT": "Back to schedule",
    "backToPrevious": "Back to previous page"
  },
