{
  "name": "edt",
  "version": "2.0.47",
  "private": true,
  "scripts": {
    "dev": "node scripts/switch-next-config.js web && next dev --turbopack",
    "prebuild": "node scripts/pre-build.js",
    "build": "node scripts/switch-next-config.js web && next build",
    "postbuild": "node scripts/post-build.js",
    "start": "next start",
    "build:web": "node scripts/switch-next-config.js web && next build",
    "build:mobile": "cross-env BUILD_MODE=mobile node scripts/switch-next-config.js mobile && next build && npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:sync": "npx cap sync android",
    "icons:android": "node scripts/generate-android-icons.js"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/local-notifications": "^6.1.2",
    "@capacitor/network": "^6.0.3",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@supabase/supabase-js": "^2.45.3",
    "next": "^16.0.0",
    "node-ical": "^0.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/react": "^19.2.2",
    "cross-env": "^7.0.3",
    "sharp": "^0.34.4",
    "typescript": "^5.9.3"
  }
}
